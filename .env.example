# Copy this file to `.env` and fill in your secrets. Never commit `.env`.
# Only secrets live here — everything else goes in ai-factory.yml.

# --- Git platform token (set the one matching git.provider in ai-factory.yml) ---
# GitHub:    a fine-grained PAT with Contents + Pull requests write on your repo.
# GitLab:    a project access token with api + write_repository scope.
# Bitbucket: an access token, or set BITBUCKET_USERNAME + an app password.
GITHUB_TOKEN=
# GITLAB_TOKEN=
# GITLAB_PROJECT_ID=
# BITBUCKET_TOKEN=
# BITBUCKET_USERNAME=

# A single GIT_TOKEN also works as a fallback for any provider.
# GIT_TOKEN=

# --- AI model API keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional integrations ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
