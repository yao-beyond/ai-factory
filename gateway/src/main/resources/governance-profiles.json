{
  "schemaVersion": 1,
  "profiles": [
    {
      "id": "standard-app",
      "version": 1,
      "enabled": true,
      "riskTier": "standard",
      "title": "一般應用",
      "description": "內部工具、實驗性功能，低敏感度。預設 profile，行為與未治理時等價。",
      "protectedPaths": [],
      "capabilities": {
        "implementer": {
          "allow": ["read:repo", "write:workspace", "run:tests", "propose:pr"],
          "deny": ["merge:main", "access:prod-secrets", "approve:own-change"]
        },
        "reviewer": {
          "allow": ["read:diff", "read:test-results", "emit:review-decision"],
          "deny": ["write:source", "merge:main", "approve:own-review"]
        }
      },
      "gates": { "beforeDeliverable": ["tests-pass", "evidence-bundle-complete"] },
      "independence": {
        "requireDistinctPrincipal": true,
        "requireReviewerReadOnly": true,
        "requireDistinctVendor": false
      },
      "humanApproval": "optional",
      "allowReviewBypass": false
    },
    {
