FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    git curl jq ca-certificates bash openssh-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY scripts /opt/ai-pipeline
RUN find /opt/ai-pipeline -name '*.sh' -exec chmod +x {} +

ENTRYPOINT ["/opt/ai-pipeline/run-task.sh"]
